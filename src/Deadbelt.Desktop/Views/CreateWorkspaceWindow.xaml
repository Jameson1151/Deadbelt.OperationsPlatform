<Window x:Class="Deadbelt.Desktop.Views.CreateWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Workspace"
        Height="420"
        Width="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Create Workspace"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>

            <TextBlock Text="Create a new Deadbelt workspace."
                       FontSize="14"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">

            <TextBlock Text="Workspace Name"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       Margin="0,0,0,6"/>

            <TextBox Text="{Binding WorkspaceName, UpdateSourceTrigger=PropertyChanged}"
                     Height="34"
                     Margin="0,0,0,18"/>

            <TextBlock Text="Workspace Folder"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       Margin="0,0,0,6"/>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                         Height="34"
                         Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                        Content="Browse"
                        Command="{Binding BrowseCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </Grid>

            <TextBlock Text="Description"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       Margin="0,0,0,6"/>

            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Height="70"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="#D9A441"
                       Margin="0,12,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Cancel"
                    Width="110"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click"
                    Margin="0,0,10,0"/>

            <Button Content="Create"
                    Width="110"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding CreateCommand}"
                    Click="Create_Click"/>
    </StackPanel>
    </Grid>
</Window>
