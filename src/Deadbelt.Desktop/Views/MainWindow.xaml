<Window x:Class="Deadbelt.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding ApplicationName}"
        Height="650"
        Width="1100"
        MinHeight="650"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="96"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="35"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">

      <Grid Margin="25,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="52"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                        Width="44"
                        Height="44"
                        VerticalAlignment="Center">
          <Border.Background>
            <ImageBrush ImageSource="../Assets/Images/deadbelt-logo.png"
                                    Stretch="Uniform"/>
          </Border.Background>
        </Border>

        <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">

          <TextBlock Text="{Binding ApplicationName}"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

          <TextBlock Text="{Binding ApplicationSubtitle}"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0,-2,0,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">

      <!-- Landing Screen -->
      <StackPanel Width="350"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsWorkspaceOpen}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>

        <TextBlock Text="{Binding WorkspaceStatus}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Margin="0,0,0,20"
                           TextAlignment="Center"/>

        <TextBlock Text="{Binding WelcomeMessage}"
                           FontSize="15"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextAlignment="Center"
                           Margin="0,0,0,40"/>

        <Button Content="Create Workspace"
                        Command="{Binding CreateWorkspaceCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,15"/>

        <Button Content="Open Workspace"
                        Command="{Binding OpenWorkspaceCommand}"
                        Style="{StaticResource SecondaryButton}"/>
      </StackPanel>

      <!-- Dashboard Shell -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

        <ScrollViewer.Style>
          <Style TargetType="ScrollViewer">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsWorkspaceOpen}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ScrollViewer.Style>

        <Grid Margin="30">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0"
                                Margin="0,0,0,25">

            <TextBlock Text="Workspace Dashboard"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>

            <TextBlock Text="{Binding ActiveWorkspaceName}"
                                   FontSize="16"
                                   Foreground="{StaticResource Brush.AccentGreen}"
                                   Margin="0,4,0,0"/>
          </StackPanel>

          <UniformGrid Grid.Row="1"
                                 Columns="4"
                                 Margin="0,0,0,25">

            <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,12,0">

              <StackPanel>
                <TextBlock Text="Workspace Overview"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           Margin="0,0,0,12"/>

                <TextBlock Text="Name"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           FontSize="12"/>

                <TextBlock Text="{Binding ActiveWorkspaceName}"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontSize="14"
                                           Margin="0,2,0,10"/>

                <TextBlock Text="Version"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           FontSize="12"/>

                <TextBlock Text="{Binding ActiveWorkspaceVersion}"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontSize="14"/>
              </StackPanel>
            </Border>

            <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,12,0">

              <StackPanel>
                <TextBlock Text="Environments"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           Margin="0,0,0,12"/>

                <TextBlock Text="0"
                                           FontSize="34"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"/>

                <TextBlock Text="Not configured"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="13"/>
              </StackPanel>
            </Border>

            <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,12,0">

              <StackPanel>
                <TextBlock Text="Providers"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           Margin="0,0,0,12"/>

                <TextBlock Text="0"
                                           FontSize="34"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"/>

                <TextBlock Text="Not configured"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="13"/>
              </StackPanel>
            </Border>

            <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">

              <StackPanel>
                <TextBlock Text="Jobs"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           Margin="0,0,0,12"/>

                <TextBlock Text="0"
                                           FontSize="34"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"/>

                <TextBlock Text="No jobs have run"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="13"/>
              </StackPanel>
            </Border>
          </UniformGrid>

          <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                                Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,12,0">

              <StackPanel>
                <TextBlock Text="Workspace Location"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           Margin="0,0,0,15"/>

                <TextBlock Text="{Binding ActiveWorkspacePath}"
                                           FontSize="14"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           TextWrapping="Wrap"/>

                <Separator Margin="0,20,0,20"
                                           Background="{StaticResource Brush.Border}"/>

                <TextBlock Text="Next Steps"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           Margin="0,0,0,10"/>

                <TextBlock Text="Environment management, provider configuration, job execution, and activity history will appear here as those platform capabilities are implemented."
                                           FontSize="14"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                                Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">

              <StackPanel>
                <TextBlock Text="Recent Activity"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           Margin="0,0,0,15"/>

                <TextBlock Text="● Workspace active"
                                           Foreground="{StaticResource Brush.AccentGreen}"
                                           FontSize="14"
                                           Margin="0,0,0,8"/>

                <TextBlock Text="● No environments configured"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="14"
                                           Margin="0,0,0,8"/>

                <TextBlock Text="● No providers configured"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="14"
                                           Margin="0,0,0,8"/>

                <TextBlock Text="● No jobs have run"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           FontSize="14"/>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </ScrollViewer>
    </Grid>

    <Border Grid.Row="2"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1,1,1,0">

      <TextBlock Text="{Binding StatusMessage}"
                       Margin="15,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
    </Border>
  </Grid>
</Window>
