<Window x:Class="Deadbelt.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding ApplicationName}"
        Height="650"
        Width="1100"
        MinHeight="650"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1B1E22">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- Header -->

        <Border Grid.Row="0"
                Background="#252A30"
                BorderBrush="#3A4149"
                BorderThickness="0,0,0,1">

            <StackPanel Margin="25,15">

                <TextBlock
                    Text="{Binding ApplicationName}"
                    FontSize="30"
                    FontWeight="SemiBold"
                    Foreground="White"/>

                <TextBlock
                    Text="{Binding ApplicationSubtitle}"
                    FontSize="14"
                    Foreground="#B5BDC7"/>

            </StackPanel>

        </Border>

        <!-- Main Content -->

        <Grid Grid.Row="1">

            <StackPanel
                Width="350"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <TextBlock
                    Text="{Binding WorkspaceStatus}"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Margin="0,0,0,20"
                    TextAlignment="Center"/>

                <TextBlock
                    Text="{Binding WelcomeMessage}"
                    FontSize="15"
                    Foreground="#B5BDC7"
                    TextAlignment="Center"
                    Margin="0,0,0,40"/>

                <Button
                    Content="Create Workspace"
                    Command="{Binding CreateWorkspaceCommand}"
                    Height="45"
                    Margin="0,0,0,15"
                    FontSize="15"/>

                <Button
                    Content="Open Workspace"
                    Command="{Binding OpenWorkspaceCommand}"
                    Height="45"
                    FontSize="15"/>

            </StackPanel>

        </Grid>

        <!-- Status Bar -->

        <Border
            Grid.Row="2"
            Background="#252A30"
            BorderBrush="#3A4149"
            BorderThickness="1,1,1,0">

            <TextBlock
                Text="{Binding StatusMessage}"
                Margin="15,0"
                VerticalAlignment="Center"
                Foreground="#B5BDC7"/>

        </Border>

    </Grid>

</Window>